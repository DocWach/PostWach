flowchart LR
  PM["PM initiates MS-B Review"]
  ORCH["MS-B Review Swarm (orchestrator)"]
  AGENTS["<b>8 Specialist Agents (parallel)</b><br/>Systems Engineer · Cybersecurity · T&E Lead · Cost Estimator<br/>Schedule · Risk · Logistics · Contracting Officer"]
  ART["Consolidated MS-B Artifacts<br/>SEP · TEMP · LCSP · APB · RMF · PoE · IMS · AS"]
  CHECK["<b>Validation + HITL Gates</b><br/>① SHACL + SPARQL (automated)<br/>② PM → Chief Engineer → MDA (human)"]
  DEC{"MS-B Decision"}
  GO(["GO: enter EMD"])
  NOGO(["NO-GO"])
  RED(["REDIRECT"])

  PM --> ORCH --> AGENTS --> ART --> CHECK
  CHECK -. fail / rework .-> ORCH
  CHECK --> DEC
  DEC --> GO
  DEC --> NOGO
  DEC --> RED

