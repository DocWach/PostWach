flowchart LR
  REQ["PM / Sponsor Request<br/>(Phase or Milestone)"]
  KB[("Knowledge Base<br/>FAR/DFARS · Pathways<br/>Templates · Governance Ontology")]
  MACQ["<b>MACQ Swarm</b> &nbsp;·&nbsp; 52 specialized agents<br/>Oversight · PMO · Phase Swarms"]
  ART["Draft Acquisition Artifacts<br/>SEP · TEMP · LCSP · APB · RMF · PoE · IMS · AS"]
  CHECK["<b>Validation + HITL Gates</b><br/>① SHACL + SPARQL (automated)<br/>② PM → Chief Engineer → MDA (human)"]
  DEC{"Decision"}
  GO(["GO"])
  NOGO(["NO-GO"])
  RED(["REDIRECT"])

  REQ --> MACQ
  KB --> MACQ
  KB -. governs .-> CHECK
  MACQ --> ART --> CHECK
  CHECK -. fail / rework .-> MACQ
  CHECK --> DEC
  DEC --> GO
  DEC --> NOGO
  DEC --> RED

