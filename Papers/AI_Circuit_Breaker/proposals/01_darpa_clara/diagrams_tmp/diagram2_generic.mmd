%% Diagram 2 (generic): Morphism Chain, domain-agnostic
%% Same structure as ECG version, neutral node labels

flowchart TB
    Z1["<b>Physical System</b><br/>real-world process<br/>Z_real"]
    Z2["<b>Sensor Output</b><br/>raw measurement<br/>analog signal"]
    Z3["<b>Digitized Signal</b><br/>ADC samples<br/>discrete waveform"]
    Z4["<b>Processed Signal</b><br/>filtered, normalized<br/>conditioned data"]
    Z5["<b>Feature Representation</b><br/>extracted descriptors<br/>or learned embedding"]
    Z6["<b>Decision</b><br/>classification or<br/>control action"]

    Z1 -->|"<b>h1:</b> Sensor Transduction<br/>D_h1 = (D_s1, D_b1)"| Z2
    Z2 -->|"<b>h2:</b> Digitization<br/>D_h2 = (D_s2, D_b2)"| Z3
    Z3 -->|"<b>h3:</b> Signal Processing<br/>D_h3 = (D_s3, D_b3)"| Z4
    Z4 -->|"<b>h4:</b> Feature Extraction<br/>D_h4 = (D_s4, D_b4)"| Z5
    Z5 -->|"<b>h5:</b> Inference / Classification<br/>D_h5 = (D_s5, D_b5)"| Z6

    T1["<b>COMPOSITION RESULT</b><br/><br/>Structural: D_s_total >= max(D_s_i)<br/>weakest link dominates<br/><br/>Behavioral: D_b_total <= sum(D_b_i)<br/>under 1-Lipschitz readouts"]

    Z6 -.->|"chain bounds"| T1

    style Z1 fill:#e74c3c,stroke:#c0392b,color:#fff
    style Z2 fill:#e67e22,stroke:#d35400,color:#fff
    style Z3 fill:#f1c40f,stroke:#f39c12,color:#333
    style Z4 fill:#3498db,stroke:#2980b9,color:#fff
    style Z5 fill:#9b59b6,stroke:#8e44ad,color:#fff
    style Z6 fill:#2ecc71,stroke:#27ae60,color:#fff
    style T1 fill:#ecf0f1,stroke:#7f8c8d,color:#333
